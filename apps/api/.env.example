# Generate both keys independently: openssl rand -base64 32
AUTH_SECRET_MASTER_KEY=
AI_SECRET_MASTER_KEY=
# Required for every non-loopback PUBLIC_ORIGIN; shown only during first administrator setup.
ADMIN_SETUP_TOKEN=
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=daylink
MYSQL_USER=daylink
MYSQL_PASSWORD=
# Advanced override; when set it takes precedence over the MYSQL_* values above.
# MYSQL_DSN=daylink:change-me@tcp(127.0.0.1:3306)/daylink
PUBLIC_ORIGIN=https://daylink.example.com
HTTP_ADDR=:8080
ASSET_DIRECTORY=/var/lib/daylink/assets
AUTO_MIGRATE=true
AI_UPSTREAM_TIMEOUT=120s
